<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:fitsSystemWindows="true">

    <!-- History (fills remaining space above display) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/history_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="4dp"
        android:clipToPadding="false" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a2a" />

    <!-- Expression display: fully app-managed, no keyboard involvement -->
    <com.github.zaegan.infinitecalc.CalculatorEditText
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:textSize="36sp"
        android:textColor="#ffffff"
        android:gravity="end|center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:background="#1a1a1a"
        android:maxLines="2"
        android:inputType="none"
        android:cursorVisible="true" />

    <!-- Live preview -->
    <TextView
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="22sp"
        android:textColor="#888888"
        android:gravity="end"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp"
        android:paddingTop="2dp"
        android:background="#1a1a1a" />

    <!-- ── Keypad area ────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="4dp">

        <!-- Row 1: STO | REC | EXT/BASIC | ⌫ | AC  (always visible) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btn_sto"
                android:layout_width="0dp" android:layout_height="56dp"
                android:layout_weight="1" android:layout_margin="2dp"
                android:text="STO" android:textColor="#ffb060" android:textSize="13sp"
                android:backgroundTint="#3a2000" />
            <Button android:id="@+id/btn_rec"
                android:layout_width="0dp" android:layout_height="56dp"
                android:layout_weight="1" android:layout_margin="2dp"
                android:text="REC" android:textColor="#60b0ff" android:textSize="13sp"
                android:backgroundTint="#001e3a" />
            <Button android:id="@+id/btn_ext"
                android:layout_width="0dp" android:layout_height="56dp"
                android:layout_weight="1.4" android:layout_margin="2dp"
                android:text="EXT" android:textColor="#aaffaa" android:textSize="12sp"
                android:backgroundTint="#0a2a0a" />
            <Button android:id="@+id/btn_backspace"
                android:layout_width="0dp" android:layout_height="56dp"
                android:layout_weight="1" android:layout_margin="2dp"
                android:text="⌫" android:textColor="#ffaaaa" android:textSize="20sp"
                android:backgroundTint="#2a1010" />
            <Button android:id="@+id/btn_clear"
                android:layout_width="0dp" android:layout_height="56dp"
                android:layout_weight="1" android:layout_margin="2dp"
                android:text="AC" android:textColor="#ff8080" android:textSize="16sp"
                android:backgroundTint="#3a0000" />
        </LinearLayout>

        <!-- ══ Regular keypad content (hidden when var panel is active) ══ -->
        <LinearLayout
            android:id="@+id/keypad_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Extended panel: hidden until EXT is toggled -->
            <LinearLayout
                android:id="@+id/extended_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Ext row 1: sin | cos | tan | ln -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <Button android:id="@+id/btn_sin"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="sin" android:textColor="#d0a0ff" android:textSize="13sp"
                        android:backgroundTint="#22103a" />
                    <Button android:id="@+id/btn_cos"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="cos" android:textColor="#d0a0ff" android:textSize="13sp"
                        android:backgroundTint="#22103a" />
                    <Button android:id="@+id/btn_tan"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="tan" android:textColor="#d0a0ff" android:textSize="13sp"
                        android:backgroundTint="#22103a" />
                    <Button android:id="@+id/btn_ln"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="ln" android:textColor="#d0a0ff" android:textSize="13sp"
                        android:backgroundTint="#22103a" />
                </LinearLayout>

                <!-- Ext row 2: RAD/DEG | % | log | 10^ -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <Button android:id="@+id/btn_rad_deg"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="RAD" android:textColor="#80ffcc" android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#003a28" />
                    <Button android:id="@+id/btn_percent"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="%" android:textColor="#80c8ff" android:textSize="17sp"
                        android:backgroundTint="#0e2840" />
                    <Button android:id="@+id/btn_log"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="log" android:textColor="#d0a0ff" android:textSize="13sp"
                        android:backgroundTint="#22103a" />
                    <Button android:id="@+id/btn_10pow"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="10^" android:textColor="#80c8ff" android:textSize="13sp"
                        android:backgroundTint="#0e2840" />
                </LinearLayout>

            </LinearLayout>

            <!-- Permanent row: ^ | √ | () | π -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_pow"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="^" android:textColor="#80c8ff" android:textSize="19sp"
                    android:backgroundTint="#0e2840" />
                <Button android:id="@+id/btn_sqrt"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="√" android:textColor="#d0a0ff" android:textSize="19sp"
                    android:backgroundTint="#22103a" />
                <Button android:id="@+id/btn_paren"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="( )" android:textColor="#60ffee" android:textSize="14sp"
                    android:backgroundTint="#003a38" />
                <Button android:id="@+id/btn_pi"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="π" android:textColor="#ffd080" android:textSize="19sp"
                    android:fontFamily="serif"
                    android:textAllCaps="false"
                    android:backgroundTint="#2a1e00" />
            </LinearLayout>

            <!-- Row 2: 7 | 8 | 9 | ÷ -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_7"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="7" android:textColor="#ffffff" android:textSize="20sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_8"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="8" android:textColor="#ffffff" android:textSize="20sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_9"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="9" android:textColor="#ffffff" android:textSize="20sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_divide"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="÷" android:textColor="#80c8ff" android:textSize="22sp"
                    android:backgroundTint="#0e2840" />
            </LinearLayout>

            <!-- Row 3: 4 | 5 | 6 | × -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_4"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="4" android:textColor="#ffffff" android:textSize="20sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_5"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="5" android:textColor="#ffffff" android:textSize="20sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_6"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="6" android:textColor="#ffffff" android:textSize="20sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_multiply"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="×" android:textColor="#80c8ff" android:textSize="22sp"
                    android:backgroundTint="#0e2840" />
            </LinearLayout>

            <!-- Row 4: 1 | 2 | 3 | − -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_1"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="1" android:textColor="#ffffff" android:textSize="20sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_2"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="2" android:textColor="#ffffff" android:textSize="20sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_3"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="3" android:textColor="#ffffff" android:textSize="20sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_subtract"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="−" android:textColor="#80c8ff" android:textSize="22sp"
                    android:backgroundTint="#0e2840" />
            </LinearLayout>

            <!-- Row 5: 0 (double-wide) | . | + -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_0"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="2" android:layout_margin="2dp"
                    android:text="0" android:textColor="#ffffff" android:textSize="20sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_decimal"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="." android:textColor="#ffffff" android:textSize="24sp"
                    android:backgroundTint="#2c2c2c" />
                <Button android:id="@+id/btn_add"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="+" android:textColor="#80c8ff" android:textSize="22sp"
                    android:backgroundTint="#0e2840" />
            </LinearLayout>

            <!-- Row 6: = (full width) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_equal"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:layout_margin="2dp"
                    android:text="=" android:textColor="#80ff90" android:textSize="26sp"
                    android:backgroundTint="#0a3a0a" />
            </LinearLayout>

        </LinearLayout>
        <!-- ══ end keypad_content ══ -->

        <!-- ══ Variable grid (replaces keypad content when STO/REC active) ══ -->
        <LinearLayout
            android:id="@+id/var_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Basic vars: A–T (20 vars, 5 rows × 4), always shown in var mode -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_var_a"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="A" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_b"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="B" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_c"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="C" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_d"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="D" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_var_e"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="E" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_f"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="F" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_g"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="G" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_h"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="H" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_var_i"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="I" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_j"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="J" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_k"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="K" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_l"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="L" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_var_m"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="M" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_n"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="N" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_o"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="O" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_p"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="P" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_var_q"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="Q" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_r"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="R" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_s"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="S" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
                <Button android:id="@+id/btn_var_t"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="2dp"
                    android:text="T" android:textColor="#c0a0ff" android:textSize="18sp"
                    android:backgroundTint="#28144a" />
            </LinearLayout>

            <!-- EXT vars: U–Z + α + β (8 vars, 2 rows × 4), shown only when EXT is active -->
            <LinearLayout
                android:id="@+id/var_ext_rows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <Button android:id="@+id/btn_var_u"
                        android:layout_width="0dp" android:layout_height="56dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="U" android:textColor="#a0c0ff" android:textSize="18sp"
                        android:backgroundTint="#142038" />
                    <Button android:id="@+id/btn_var_v"
                        android:layout_width="0dp" android:layout_height="56dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="V" android:textColor="#a0c0ff" android:textSize="18sp"
                        android:backgroundTint="#142038" />
                    <Button android:id="@+id/btn_var_w"
                        android:layout_width="0dp" android:layout_height="56dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="W" android:textColor="#a0c0ff" android:textSize="18sp"
                        android:backgroundTint="#142038" />
                    <Button android:id="@+id/btn_var_x"
                        android:layout_width="0dp" android:layout_height="56dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="X" android:textColor="#a0c0ff" android:textSize="18sp"
                        android:backgroundTint="#142038" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <Button android:id="@+id/btn_var_y"
                        android:layout_width="0dp" android:layout_height="56dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="Y" android:textColor="#a0c0ff" android:textSize="18sp"
                        android:backgroundTint="#142038" />
                    <Button android:id="@+id/btn_var_z"
                        android:layout_width="0dp" android:layout_height="56dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="Z" android:textColor="#a0c0ff" android:textSize="18sp"
                        android:backgroundTint="#142038" />
                    <Button android:id="@+id/btn_var_alpha"
                        android:layout_width="0dp" android:layout_height="56dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="α" android:textColor="#a0c0ff" android:textSize="18sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#142038" />
                    <Button android:id="@+id/btn_var_beta"
                        android:layout_width="0dp" android:layout_height="56dp"
                        android:layout_weight="1" android:layout_margin="2dp"
                        android:text="β" android:textColor="#a0c0ff" android:textSize="18sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#142038" />
                </LinearLayout>

            </LinearLayout>
            <!-- ══ end var_ext_rows ══ -->

            <!-- = stays visible in var mode so the user has a stable anchor -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_equal_var"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:layout_margin="2dp"
                    android:text="=" android:textColor="#80ff90" android:textSize="26sp"
                    android:backgroundTint="#0a3a0a" />
            </LinearLayout>

        </LinearLayout>
        <!-- ══ end var_grid ══ -->

    </LinearLayout>

</LinearLayout>
